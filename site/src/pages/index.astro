---
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';

const repo = 'https://github.com/dylanp12/proctor';
const title = 'Proctor — signed, verifiable integrity bundles for AI benchmarks';
const description =
	'Proctor runs AI coding-agent benchmark tasks in an answer-isolated Linux sandbox where the hidden tests, fix history, and network are unreachable, then signs a verdict — and the record of every cheat attempted — that anyone can verify.';
const canonical = 'https://proctorbench.dev/';

// The signature: a real run, caught and then independently verified.
const transcript = [
	{ k: 'cmd', t: '$ proctor run --task ./tb/oracle-task --agent "agent --solve"' },
	{ k: 'sys', t: '[proctor] sandbox up · oracle masked · netns empty · repo @ base commit' },
	{ k: 'agent', t: 'agent   cat /oracle/expected_output.txt' },
	{ k: 'deny', t: 'sh: /oracle/expected_output.txt: No such file or directory', tag: 'ENOENT' },
	{ k: 'agent', t: 'agent   curl -s https://paste.example/answer' },
	{ k: 'deny', t: 'curl: (6) could not resolve host', tag: 'ENETUNREACH' },
	{ k: 'breach', t: '[proctor] verdict  status=compromised  pass=true  violations=2', tag: 'compromised' },
	{ k: 'cmd', t: '$ proctor verify-bundle --bundle out/bundle.json --pubkey c28e…6797' },
	{ k: 'ok', t: 'bundle OK · signature valid · chain bound · 2 violations · env matched', tag: 'verified' },
];

const ld = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Proctor',
	applicationCategory: 'DeveloperApplication',
	operatingSystem: 'Linux',
	description,
	url: canonical,
	codeRepository: repo,
	license: 'https://opensource.org/licenses/MIT',
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content="https://proctorbench.dev/og.png" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://proctorbench.dev/og.png" />
		<script type="application/ld+json" set:html={JSON.stringify(ld)} />
	</head>
	<body>
		<a class="skip" href="#main">Skip to content</a>
		<header class="nav">
			<a class="wordmark" href="/">proctor<span class="cursor">_</span></a>
			<nav class="nav-links">
				<a href="/docs/overview/">Docs</a>
				<a href="/docs/bundle-spec/">Bundle spec</a>
				<a href="/blog/benchmark-cheating-dies-by-construction/">Writeup</a>
				<a class="ghlink" href={repo}>GitHub ↗</a>
			</nav>
		</header>

		<main id="main">
			<!-- HERO -->
			<section class="hero">
				<p class="eyebrow">signed · verifiable · benchmark integrity</p>
				<h1>
					The leaderboard says the agent passed.
					<span class="prove">Prove it.</span>
				</h1>
				<p class="lede">
					Proctor runs AI coding agents in a Linux sandbox where the answer was never placed —
					hidden tests, fix history, and the network are out of reach by construction. Then it
					signs a verdict, and the record of every cheat the agent tried, that anyone can verify.
				</p>
				<div class="cta-row">
					<a class="btn btn-primary" href="/docs/quickstart/">Verify it in 60s</a>
					<a class="btn" href="/blog/benchmark-cheating-dies-by-construction/">Read the writeup</a>
					<a class="btn btn-ghost" href={repo}>★ GitHub</a>
				</div>

				<figure class="term" aria-label="A Proctor run: two cheat attempts denied, the verdict marked compromised, then independently verified.">
					<div class="term-bar"><span></span><span></span><span></span><b>proctor run</b></div>
					<div class="term-body">
						{transcript.map((l, i) => (
							<div class={`ln ln-${l.k}`} style={`--i:${i}`}>
								<span class="ln-t">{l.t}</span>
								{l.tag && <span class={`tag tag-${l.k}`}>{l.tag}</span>}
							</div>
						))}
					</div>
				</figure>
			</section>

			<!-- PROBLEM -->
			<section class="band band-breach">
				<p class="kicker kicker-breach">the problem</p>
				<div class="stat-row">
					<div class="stat">
						<span class="stat-num">415<span class="stat-den">/429</span></span>
						<p class="stat-cap">
							"successful" Terminal-Bench 2 runs in one removed submission that were just
							<code>cat /tests</code> — reading the answer, not solving the task.
						</p>
					</div>
					<div class="stat-prose">
						<p>
							AI coding-agent benchmarks drive model launches, hiring, and procurement — and
							they leak. A 2026 UPenn study documented agents reading the test oracle, mining
							<code>git log</code> for the fix commit, <code>curl</code>-ing the answer, and
							pre-writing the grader's reward file across nine benchmarks.
						</p>
						<p class="stat-note">
							Every one is a sandboxing failure, not a modeling one. The study's own
							prescription: <em>isolate the agent from the evaluator.</em>
						</p>
						<p class="cite">
							<a href="https://debugml.github.io/cheating-agents/">DebugML, “Finding Widespread Cheating on Popular Agent Benchmarks”</a> ·
							<a href="https://arxiv.org/abs/2604.11806">arXiv:2604.11806</a>
						</p>
					</div>
				</div>
			</section>

			<!-- HOW IT WORKS -->
			<section class="band">
				<p class="kicker kicker-mint">how it works — by construction</p>
				<h2>Four walls. Each one kills a documented cheat at the syscall.</h2>
				<div class="walls">
					<div class="wall">
						<p class="wall-syscall">open() → <span class="deny-code">ENOENT</span></p>
						<h3>The oracle isn't in its filesystem</h3>
						<p>Tests, solutions, and reward files are masked from the mount namespace. Reading the answer doesn't fail a check — the file simply isn't there.</p>
					</div>
					<div class="wall">
						<p class="wall-syscall">connect() → <span class="deny-code">ENETUNREACH</span></p>
						<h3>The network namespace is empty</h3>
						<p>Direct egress dies. Allowlist mode bridges only approved hosts through a host-side proxy — and logs every decision into the signed timeline.</p>
					</div>
					<div class="wall">
						<p class="wall-syscall">git log → <span class="deny-code">unreachable</span></p>
						<h3>The repo stops at the base commit</h3>
						<p>Fix history is never transferred, so mining <code>git log</code> for the answer patch finds nothing to copy.</p>
					</div>
					<div class="wall">
						<p class="wall-syscall">seccomp → <span class="mint-code">signed trail</span></p>
						<h3>Every attempt is recorded</h3>
						<p>A user-notification monitor logs each forbidden <code>open</code>/<code>connect</code> into a hash-chained timeline. The mounts are the wall; the monitor is the receipt.</p>
					</div>
				</div>
				<p class="band-foot"><a href="/docs/how-it-works/">How it works, in full →</a></p>
			</section>

			<!-- TRUST IT -->
			<section class="band band-trust">
				<p class="kicker kicker-mint">trust it</p>
				<h2>A run you can hand to a stranger.</h2>
				<p class="trust-lede">
					Every run emits a portable <code>bundle.json</code> — verdict, violation timeline, log
					hashes, and the recorded environment, under one ed25519 signature.
					<code>verify-bundle</code> fails closed unless all four checks pass:
				</p>
				<ol class="checks">
					<li><b>Signature</b> — the body is exactly what the operator's key signed.</li>
					<li><b>Chain</b> — the violation timeline recomputes to the signed head.</li>
					<li><b>Artifacts</b> — the agent-log hashes match the manifest.</li>
					<li><b>Environment</b> — the recorded command, image, version, and policy recompute to the signed digest.</li>
				</ol>
				<div class="verify-box">
					<code class="vb-cmd">$ proctor verify-bundle --bundle sample-bundle.json --pubkey c28e…6797</code>
					<code class="vb-out">bundle OK · signature valid · chain bound · 1 violation · status=Compromised</code>
				</div>
				<p class="band-foot">
					<a href="/docs/example-bundle/">Verify the real example bundle →</a> &nbsp;·&nbsp;
					<a href="/docs/bundle-spec/">What a verifier can &amp; can't conclude →</a>
				</p>
			</section>

			<!-- HONEST SCOPE -->
			<section class="band band-scope">
				<p class="kicker">honest scope</p>
				<h2>What it does <span class="not">not</span> do.</h2>
				<p class="scope-lede">An integrity tool that overclaims is worse than none. Proctor blocks <em>in-sandbox access</em> cheats. It does not pretend to cover:</p>
				<ul class="nongoals">
					<li><b>Scaffold-injected answer keys</b> — the answer arrives in the agent's prompt, from outside the sandbox.</li>
					<li><b>Solutions baked into the agent binary</b> — the agent carries the answer in.</li>
					<li><b>Grader-fooling</b> — <code>PASS</code>-greps, hardcoded outputs, mocks — a grader-hardening problem.</li>
				</ul>
				<p class="band-foot">These need submission provenance or grader hardening — the <a href="/docs/roadmap/">roadmap</a>. <a href="/docs/honest-scope/">Read the full scope →</a></p>
			</section>

			<!-- CTA -->
			<section class="closer">
				<h2>Run one task under Proctor. Tell us what breaks.</h2>
				<p>Rust, Linux, unprivileged — no root, no VM, no daemon. The corpus is green in CI on a stock runner.</p>
				<div class="cta-row">
					<a class="btn btn-primary" href="/docs/quickstart/">Get started</a>
					<a class="btn btn-ghost" href={repo}>★ Star on GitHub</a>
				</div>
			</section>
		</main>

		<footer class="foot">
			<span class="wordmark sm">proctor<span class="cursor">_</span></span>
			<nav>
				<a href="/docs/overview/">Docs</a>
				<a href="/docs/bundle-spec/">Bundle spec</a>
				<a href="/blog/benchmark-cheating-dies-by-construction/">Writeup</a>
				<a href={repo}>GitHub</a>
			</nav>
			<span class="foot-meta">MIT · v0.1.1 · Linux</span>
		</footer>

		<style is:global>
			:root {
				--ink: #0a0f0e; --ink-2: #0e1513; --ink-3: #121b18;
				--line: #1f2a27; --bone: #e8edeb; --muted: #90a39d;
				--mint: #46d6a8; --mint-dim: #2a8268; --coral: #ff6a5a; --coral-dim: #7c2f29;
				--display: 'Space Grotesk', system-ui, sans-serif;
				--body: 'Inter', system-ui, sans-serif;
				--mono: 'JetBrains Mono', ui-monospace, monospace;
				--wrap: 70rem;
			}
			* { box-sizing: border-box; }
			html { scroll-behavior: smooth; }
			body {
				margin: 0; background: var(--ink); color: var(--bone);
				font-family: var(--body); font-size: 17px; line-height: 1.65;
				-webkit-font-smoothing: antialiased;
			}
			a { color: var(--mint); text-decoration: none; }
			a:hover { text-decoration: underline; }
			code { font-family: var(--mono); font-size: 0.88em; color: #cfe6dd; }
			.skip { position: absolute; left: -999px; }
			.skip:focus { left: 1rem; top: 1rem; background: var(--mint); color: var(--ink); padding: .5rem .8rem; border-radius: 6px; z-index: 10; }
			:focus-visible { outline: 2px solid var(--mint); outline-offset: 2px; }
			h1, h2, h3 { font-family: var(--display); font-weight: 700; line-height: 1.1; letter-spacing: -0.02em; }

			/* NAV */
			.nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem;
				max-width: var(--wrap); margin: 0 auto; padding: 1.3rem 1.5rem; }
			.wordmark { font-family: var(--mono); font-weight: 700; font-size: 1.15rem; color: var(--bone); letter-spacing: -0.04em; }
			.wordmark .cursor { color: var(--mint); }
			.wordmark.sm { font-size: 1rem; }
			.nav-links { display: flex; gap: 1.4rem; align-items: center; font-family: var(--mono); font-size: 0.82rem; }
			.nav-links a { color: var(--muted); }
			.nav-links a:hover { color: var(--bone); text-decoration: none; }
			.nav-links .ghlink { color: var(--bone); }

			/* HERO */
			.hero { max-width: var(--wrap); margin: 0 auto; padding: 3.5rem 1.5rem 1rem; }
			.eyebrow { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mint); margin: 0 0 1.2rem; }
			.kicker-mint, .eyebrow { color: var(--mint); }
			h1 { font-size: clamp(2.4rem, 6vw, 4.2rem); margin: 0; max-width: 18ch; }
			h1 .prove { display: block; color: var(--mint); }
			.lede { font-size: clamp(1.05rem, 2.2vw, 1.3rem); color: var(--muted); max-width: 52ch; margin: 1.6rem 0 2rem; }
			.cta-row { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 3rem; }
			.btn { font-family: var(--mono); font-size: 0.9rem; font-weight: 500; padding: 0.7rem 1.2rem;
				border-radius: 8px; border: 1px solid var(--line); color: var(--bone); transition: all .15s ease; }
			.btn:hover { text-decoration: none; border-color: var(--mint-dim); transform: translateY(-1px); }
			.btn-primary { background: var(--mint); color: #06120d; border-color: var(--mint); font-weight: 700; }
			.btn-primary:hover { background: #5fe6bb; }
			.btn-ghost { color: var(--muted); }

			/* TERMINAL — the signature */
			.term { margin: 0; border: 1px solid var(--line); border-radius: 12px; overflow: hidden;
				background: linear-gradient(180deg, #0c1411, #0a100e); box-shadow: 0 30px 80px -40px #000; }
			.term-bar { display: flex; align-items: center; gap: 0.45rem; padding: 0.7rem 1rem; border-bottom: 1px solid var(--line); background: #0c1310; }
			.term-bar span { width: 11px; height: 11px; border-radius: 50%; background: #233029; }
			.term-bar b { font-family: var(--mono); font-size: 0.75rem; font-weight: 500; color: var(--muted); margin-left: 0.5rem; }
			.term-body { padding: 1.1rem 1.2rem; font-family: var(--mono); font-size: clamp(0.72rem, 1.5vw, 0.86rem); line-height: 1.9; overflow-x: auto; }
			.ln { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; white-space: pre;
				opacity: 0; transform: translateY(4px); animation: rise 0.45s ease forwards; animation-delay: calc(var(--i) * 0.16s); }
			.ln-t { min-width: 0; }
			.ln-cmd .ln-t { color: var(--bone); }
			.ln-sys .ln-t { color: var(--mint-dim); }
			.ln-agent .ln-t { color: #cdb9ff; }
			.ln-deny .ln-t { color: var(--coral); }
			.ln-breach .ln-t { color: var(--coral); font-weight: 700; }
			.ln-ok .ln-t { color: var(--mint); font-weight: 700; }
			.tag { font-size: 0.72em; font-weight: 700; padding: 0.05rem 0.45rem; border-radius: 5px; border: 1px solid currentColor; flex: none; }
			.tag-deny, .tag-breach { color: var(--coral); background: #1a0e0d; }
			.tag-ok { color: var(--mint); background: #06180f; }
			@keyframes rise { to { opacity: 1; transform: none; } }

			/* BANDS */
			.band { max-width: var(--wrap); margin: 0 auto; padding: 5rem 1.5rem; border-top: 1px solid var(--line); }
			.band h2 { font-size: clamp(1.7rem, 3.5vw, 2.5rem); margin: 0.4rem 0 2rem; max-width: 20ch; }
			.kicker { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0; }
			.kicker-breach { color: var(--coral); }
			.band-foot { font-family: var(--mono); font-size: 0.85rem; margin-top: 2rem; }

			/* PROBLEM */
			.band-breach { background: radial-gradient(120% 100% at 0% 0%, #14100f, transparent 60%); }
			.stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 1.5rem; align-items: start; }
			.stat-num { font-family: var(--display); font-weight: 700; font-size: clamp(3.5rem, 9vw, 6rem); color: var(--coral); line-height: 0.9; letter-spacing: -0.04em; }
			.stat-den { font-size: 0.4em; color: var(--coral-dim); }
			.stat-cap { color: var(--muted); margin-top: 0.8rem; max-width: 32ch; }
			.stat-prose p { margin: 0 0 1rem; }
			.stat-note { color: var(--bone); }
			.cite { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); }
			.cite a { color: var(--muted); }

			/* WALLS */
			.walls { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
			.wall { background: var(--ink-2); padding: 1.8rem; }
			.wall-syscall { font-family: var(--mono); font-size: 0.82rem; color: var(--muted); margin: 0 0 0.9rem; }
			.deny-code { color: var(--coral); }
			.mint-code { color: var(--mint); }
			.wall h3 { font-size: 1.15rem; margin: 0 0 0.5rem; }
			.wall p { color: var(--muted); margin: 0; font-size: 0.96rem; }

			/* TRUST */
			.band-trust { background: radial-gradient(120% 100% at 100% 0%, #0b1714, transparent 55%); }
			.trust-lede { color: var(--muted); max-width: 60ch; }
			.checks { list-style: none; counter-reset: c; padding: 0; margin: 2rem 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
			.checks li { counter-increment: c; position: relative; padding: 1rem 1rem 1rem 3rem; background: var(--ink-2); border: 1px solid var(--line); border-radius: 10px; color: var(--muted); font-size: 0.95rem; }
			.checks li b { color: var(--bone); }
			.checks li::before { content: counter(c); position: absolute; left: 1rem; top: 1rem; font-family: var(--mono); font-weight: 700; color: var(--mint); }
			.verify-box { background: #0a100e; border: 1px solid var(--line); border-left: 3px solid var(--mint); border-radius: 10px; padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.4rem; overflow-x: auto; }
			.vb-cmd { color: var(--bone); white-space: pre; }
			.vb-out { color: var(--mint); white-space: pre; }

			/* SCOPE */
			.not { color: var(--coral); font-style: italic; }
			.scope-lede { color: var(--muted); max-width: 58ch; }
			.nongoals { list-style: none; padding: 0; margin: 1.8rem 0; display: grid; gap: 0.7rem; }
			.nongoals li { padding: 0.9rem 1.1rem; background: var(--ink-2); border: 1px solid var(--line); border-radius: 10px; color: var(--muted); }
			.nongoals li b { color: var(--bone); }

			/* CLOSER */
			.closer { max-width: var(--wrap); margin: 0 auto; padding: 6rem 1.5rem; text-align: center; border-top: 1px solid var(--line); }
			.closer h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin: 0 auto 1rem; max-width: 22ch; }
			.closer p { color: var(--muted); margin: 0 auto 2rem; max-width: 50ch; }
			.closer .cta-row { justify-content: center; margin-bottom: 0; }

			/* FOOTER */
			.foot { max-width: var(--wrap); margin: 0 auto; padding: 2.5rem 1.5rem; border-top: 1px solid var(--line);
				display: flex; flex-wrap: wrap; align-items: center; gap: 1.2rem; justify-content: space-between; }
			.foot nav { display: flex; gap: 1.3rem; font-family: var(--mono); font-size: 0.82rem; }
			.foot nav a { color: var(--muted); }
			.foot-meta { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); }

			@media (max-width: 760px) {
				.stat-row, .walls, .checks { grid-template-columns: 1fr; }
				.nav-links { gap: 0.9rem; }
				.nav-links a:not(.ghlink):not(:first-child) { display: none; }
			}
			@media (prefers-reduced-motion: reduce) {
				html { scroll-behavior: auto; }
				.ln { opacity: 1; transform: none; animation: none; }
			}
		</style>
	</body>
</html>
